@{
    ViewData["Title"] = "Actividades por Colaborador";
}

<h1>Actividades por Colaborador</h1>

<div class="mb-3">
    <button class="btn btn-primary" id="btnNuevaActividad">
        Nueva Actividad
    </button>
</div>

<table class="table table-striped" id="tablaActividadColaborador">
    <thead>
        <tr>
            <th>ID</th>
            <th>Actividad</th>
            <th>Descripción</th>
            <th>Estatus</th>
            <th>Rol</th>
            <th>Fecha Creada</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <!-- Se llenará vía JS -->
    </tbody>
</table>

@await Html.PartialAsync("_ModalCrear")
@await Html.PartialAsync("_ModalEditar")

@section Scripts {
    <script src="~/js/actividadColaborador.js"></script>
}